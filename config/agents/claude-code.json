{
  "schemaVersion": 1,
  "kind": "agent-tool-semantics",
  "id": "claude-code",
  "ontology": "coding",
  "description": "Per-agent layer for Claude Code. Maps each tool name + input to an ontology action and a target field, plus the freeform-command grammar for Bash and the harness-internal markers/structural roles. Every `action` and `object` value here MUST be an id defined in ontology/coding.json. This file externalizes what derive.ts currently hardcodes (TOOL_HANDLERS, describePath, SUGGESTION_MARKER, session-title, thinking/tool_use roles).",

  "targetKinds": {
    "path": "Take the named input field as a filesystem path; hand it to project grounding to resolve an object type and label.",
    "host": "Reduce a URL field to its host for display.",
    "literal": "Use the field value verbatim as the display target.",
    "none": "Tool has no meaningful target."
  },

  "wellKnownPaths": {
    "note": "Paths the AGENT owns, wherever they live on disk (not project-relative). First regex match wins; the label is the full semantic name and suppresses the grounded-type suffix. This is Claude Code's own config layout, so it belongs here, not in project grounding.",
    "rules": [
      { "match": "/\\.claude/settings\\.json$", "label": "claude code user settings" },
      { "match": "/\\.claude/", "label": "claude code config" }
    ]
  },

  "tools": {
    "Read": {
      "action": "read",
      "target": { "field": "file_path", "kind": "path" },
      "phrase": "read {object}"
    },
    "Edit": {
      "action": "edit",
      "target": { "field": "file_path", "kind": "path" },
      "phrase": "edit {object}"
    },
    "MultiEdit": {
      "action": "edit",
      "target": { "field": "file_path", "kind": "path" },
      "phrase": "edit {object}",
      "note": "deprecated alias of Edit"
    },
    "Write": {
      "action": "write",
      "target": { "field": "file_path", "kind": "path" },
      "phrase": "write {object}"
    },
    "NotebookEdit": {
      "action": "edit",
      "target": { "field": "notebook_path", "kind": "path" },
      "phrase": "edit {object}",
      "note": "edit_mode disambiguates the semantic action deterministically from the input — no model needed.",
      "overrides": [
        {
          "when": { "field": "edit_mode", "equals": "insert" },
          "action": "write",
          "phrase": "add cell to {object}"
        },
        {
          "when": { "field": "edit_mode", "equals": "delete" },
          "action": "delete",
          "phrase": "delete cell from {object}"
        }
      ]
    },
    "Glob": {
      "action": "search",
      "target": { "field": "pattern", "kind": "literal" },
      "phrase": "find files matching {target}"
    },
    "Grep": {
      "action": "search",
      "target": { "field": "pattern", "kind": "literal" },
      "phrase": "search code for {target}"
    },
    "WebFetch": {
      "action": "fetch",
      "target": { "field": "url", "kind": "host" },
      "phrase": "fetch {target}",
      "modifiers": [
        {
          "when": { "field": "prompt", "matches": "summar" },
          "append": { "action": "respond", "label": "summarize content" }
        }
      ]
    },
    "WebSearch": {
      "action": "search-web",
      "target": { "field": "query", "kind": "literal" },
      "phrase": "search the web for {target}"
    },
    "Task": {
      "action": "delegate",
      "target": { "field": "subagent_type", "kind": "literal" },
      "phrase": "delegate to {target} subagent"
    },
    "Agent": {
      "action": "delegate",
      "target": { "field": "subagent_type", "kind": "literal" },
      "phrase": "delegate to {target} subagent",
      "note": "current name for Task"
    },
    "TodoWrite": {
      "action": "plan",
      "object": "task-list",
      "target": { "kind": "none" },
      "phrase": "update task list"
    },
    "ExitPlanMode": {
      "action": "plan",
      "object": "repo",
      "target": { "kind": "none" },
      "phrase": "present plan for approval"
    },
    "AskUserQuestion": {
      "action": "clarify",
      "object": "user",
      "target": { "kind": "none" },
      "phrase": "ask the user"
    },
    "Skill": {
      "action": "use-skill",
      "target": { "field": "skill", "kind": "literal" },
      "phrase": "use {target} skill",
      "overrides": [
        {
          "when": { "field": "skill", "equals": "update-config" },
          "action": "configure",
          "object": "agent-config",
          "label": "update claude code config"
        }
      ]
    },
    "SlashCommand": {
      "action": "use-skill",
      "target": { "field": "command", "kind": "literal", "extract": "^/?([A-Za-z0-9_-]+)" },
      "phrase": "run {target} command",
      "note": "Custom project slash command (.claude/commands/*.md), distinct from the Skill tool. Field is `command` (e.g. '/review-pr 123')."
    },
    "ToolSearch": {
      "action": "load-schema",
      "object": "tool",
      "target": { "field": "query", "kind": "literal", "extract": "select:([A-Za-z0-9_]+)" },
      "phrase": "load {target} tool schema",
      "fallbackPhrase": "load tool schema"
    },
    "BashOutput": {
      "action": "read",
      "object": "shell",
      "target": { "kind": "none" },
      "phrase": "read command output"
    },
    "KillShell": {
      "action": "run",
      "object": "shell",
      "target": { "kind": "none" },
      "phrase": "kill background command"
    },
    "Bash": {
      "escapeHatch": true,
      "target": { "field": "command", "kind": "literal" },
      "note": "Freeform command — action/object come from bashCommandGrammar (first match wins). Project grounding may override via its own `commands` rules before this generic grammar applies.",
      "grammarRef": "bashCommandGrammar"
    },

    "_unknownTool": {
      "note": "Any tool not listed (including mcp__* and project slash commands) falls back to: action `act`, object `unknown`, phrase = lowercased tool name. Surfaced as low-confidence so the gap is visible.",
      "action": "act",
      "object": "unknown",
      "phrase": "{toolNameLower}"
    }
  },

  "bashCommandGrammar": {
    "note": "Ordered; first regex (matched case-insensitively against the trimmed command) wins. The final catch-all guarantees a label. Object is often left to project grounding when it depends on which file the command touches.",
    "rules": [
      { "match": "^(pnpm|npm|yarn|bun)\\s+(run\\s+)?lint", "action": "lint" },
      { "match": "\\beslint\\b", "action": "lint" },
      { "match": "\\bknip\\b", "action": "lint", "object": "repo", "label": "check for dead code" },
      { "match": "\\bprettier\\b", "action": "format" },
      { "match": "^(pnpm|npm|yarn|bun)\\s+(run\\s+)?format", "action": "format" },
      { "match": "\\b(tsc|tsgo)\\b|typecheck", "action": "typecheck" },
      {
        "match": "\\b(vitest|jest|mocha|pytest|go\\s+test|cargo\\s+test|rspec)\\b",
        "action": "test",
        "object": "test-code"
      },
      {
        "match": "^(pnpm|npm|yarn|bun)\\s+(run\\s+)?test",
        "action": "test",
        "object": "test-code"
      },
      {
        "match": "^(pnpm|npm|yarn|bun)\\s+(run\\s+)?build|\\btsup\\b|\\bvite build\\b|\\bwebpack\\b",
        "action": "build"
      },
      {
        "match": "^(pnpm|npm|yarn|bun)\\s+(install|add|remove|i)\\b",
        "action": "configure",
        "object": "dependency"
      },
      { "match": "^git\\s+commit\\b", "action": "vcs", "label": "commit changes" },
      {
        "match": "^git\\s+(push|pull|fetch|merge|rebase|checkout|switch|branch|stash|tag)\\b",
        "action": "vcs"
      },
      { "match": "^gh\\s+pr\\b", "action": "vcs", "label": "manage pull request" },
      { "match": "^git\\s+(status|log|diff|show|blame)\\b", "action": "read", "object": "repo" },
      { "match": "^(ls|cat|head|tail|find|rg|grep|tree|pwd|wc|stat)\\b", "action": "read" },
      { "match": "^(mkdir|touch|cp|mv)\\b", "action": "write" },
      { "match": "^rm\\b", "action": "delete" },
      { "match": "^(curl|wget)\\b", "action": "fetch", "object": "web-resource" },
      { "match": ".*", "action": "run", "object": "shell" }
    ]
  },

  "markers": {
    "note": "Deterministic short-circuits at the llm_request level — these fully determine the label and pre-empt any model call. Each is exactly what derive.ts detects today.",
    "rules": [
      {
        "id": "session-title",
        "when": { "responseJsonHasStringKey": "title" },
        "action": "generate-title",
        "object": "repo"
      },
      {
        "id": "suggestion-mode",
        "when": { "requestTextStartsWith": "[SUGGESTION MODE" },
        "action": "predict",
        "object": "user"
      }
    ]
  },

  "structuralRoles": {
    "note": "Deterministic prefix phrases derived from response-message structure. Prepended to (not replacing) any model classification of a final message. Mirrors structuralPrefix() in semantic.ts.",
    "rules": [
      {
        "id": "thinking",
        "when": { "responseHasBlockType": "thinking" },
        "action": "plan",
        "phrase": "plan next steps"
      },
      {
        "id": "tool_use",
        "when": { "responseEndsWithBlockType": "tool_use" },
        "action": "invoke",
        "phrase": "invoke {toolPhrase}",
        "overrides": [{ "when": { "toolName": "Skill" }, "phrase": "decide on skill use" }]
      }
    ]
  },

  "modelResidual": {
    "note": "What is LEFT for the weak model after all of the above. Only fires for a genuine terminal assistant message (response_text present AND the turn does not end in a tool_use). The model classifies the ACT into an ordered list of phrases, each a verb from the ontology's `messageActs` paired with a generic object (e.g. ['confirm edit','suggest next steps']); it never quotes the message. Everything else is deterministic. messageActs is a distinct axis from the leaf `actions` (which are derived, not modeled); the label-batch prompt is generated from that list, so add a verb to the ontology rather than editing the prompt.",
    "constrainTo": "ontology.messageActs verbs",
    "outputShape": "ordered string[] of '<verb> <generic object>' phrases"
  }
}
