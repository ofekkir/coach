{
  "name": "@coach/mcp",
  "version": "0.1.0",
  "description": "Distributable MCP server that turns agent OTEL/native traces into a queryable execution graph, plus the bundled analyze-traces skill.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ofek/coach.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "coach-mcp": "./dist/bin/mcp.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "node --experimental-strip-types bin/mcp.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@coach/pipeline": "workspace:*",
    "@coach/semantics": "workspace:*",
    "@types/node": "^22.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
